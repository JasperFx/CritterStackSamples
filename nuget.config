<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" />
    <add key="CritterWatch-local" value="../CritterWatch/artifacts/nupkgs" />
  </packageSources>
  <packageSourceMapping>
    <packageSource key="nuget.org">
      <package pattern="*" />
    </packageSource>
    <packageSource key="CritterWatch-local">
      <package pattern="CritterWatch*" />
      <package pattern="Wolverine.CritterWatch*" />
    </packageSource>
  </packageSourceMapping>
</configuration>
